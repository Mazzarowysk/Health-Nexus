{
  "name": "health-nexus",
  "version": "1.0.0",
  "description": "Health Nexus - Software de Gestão Hospitalar",
  "main": "backend/server.js",
  "type": "module",
  "scripts": {
    "dev:frontend": "node node_modules/vite/bin/vite.js",
    "dev:backend": "nodemon backend/server.js",
    "dev": "concurrently --kill-others \"node node_modules/vite/bin/vite.js\" \"cross-env NODE_ENV=development node backend/server.js\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node backend/server.js"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.0",
    "vite": "^5.2.11"
  }
}
